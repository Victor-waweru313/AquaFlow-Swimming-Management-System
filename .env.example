# =============================================================================
# AquaFlow Environment Configuration
# =============================================================================

# Database Configuration
# For local development with PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/aquaflow
# 
# For Vercel Postgres (use Vercel dashboard to connect):
DATABASE_URL=postgresql://[user[:password]@][netloc][:port][/dbname]

# Authentication
# NEXTAUTH_URL: The URL where your application is hosted
# For local development:
NEXTAUTH_URL=http://localhost:3000
# For production (replace with your Vercel domain):
# NEXTAUTH_URL=https://aquaflow-production.vercel.app

# NEXTAUTH_SECRET: A random string used for encryption (minimum 32 characters)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here-min-32-chars-required

# =============================================================================
# VERCEL DEPLOYMENT NOTES
# =============================================================================
# 1. These environment variables will be configured in Vercel dashboard
# 2. DATABASE_URL will be provided by Vercel Postgres
# 3. NEXTAUTH_SECRET will be auto-generated by Vercel (or create your own)
